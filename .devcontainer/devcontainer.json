{
	"name": "Multi-container Dev Environment",
	"image": "mcr.microsoft.com/devcontainers/universal:2-linux",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/azure-cli:1": {},
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/dotnet/aspire-devcontainer-feature/dotnetaspire:1": {}
	},
	"forwardPorts": [
		15888,
		16686,
		5000,
		5001,
		7000,
		7001,
		7002,
		7003,
		7004
	],
    "postCreateCommand": "sudo dotnet workload install aspire",
	"portsAttributes": {
		"15888": {
			"label": "Aspire Dashboard",
			"onAutoForward": "openBrowser"
		},
		"16686": {
			"label": "OpenTelemetry Collector"
		},
		"5000": {
			"label": "HTTP Services"
		},
		"5001": {
			"label": "HTTPS Services"
		},
		"7000": {
			"label": "Knowledge Agent"
		},
		"7001": {
			"label": "Planning Agent"
		},
		"7002": {
			"label": "Development Agent"
		},
		"7003": {
			"label": "User Delegation Agent"
		},
		"7004": {
			"label": "Workflow Agent"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"ms-azuretools.vscode-containers",
				"ms-dotnettools.csdevkit",
				"ms-windows-ai-studio.windows-ai-studio",
				"ms-semantic-kernel.semantic-kernel",
				"azsdktm.SecurityIntelliSense",
				"genaiscript.genaiscript-vscode",
				"PDETs-prod.AI-Powered-Authoring",
				"ms-windows-ai-studio.microsoft-ai-tools-pack",
				"PDETs-prod.new-module-creation",
				"ms-vscode.copilot-mermaid-diagram"
			]
		}
	}
}
