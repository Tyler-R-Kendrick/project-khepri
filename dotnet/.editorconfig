# StyleCop Analyzers - Configuration for specific rules
dotnet_diagnostic.SA0002.severity = none  # StyleCop.json configuration file not found
dotnet_diagnostic.SA1005.severity = warning  # Single line comment should begin with a space
dotnet_diagnostic.SA1009.severity = warning  # Closing parenthesis should not be preceded by a space
dotnet_diagnostic.SA1025.severity = warning  # Code should not contain multiple whitespace characters in a row
dotnet_diagnostic.SA1028.severity = warning  # Code should not contain trailing whitespace
dotnet_diagnostic.SA1110.severity = warning  # Opening parenthesis or bracket should be on declaration line
dotnet_diagnostic.SA1111.severity = warning  # Closing parenthesis should be on line of last parameter
dotnet_diagnostic.SA1116.severity = warning  # Split parameters should start on line after declaration
dotnet_diagnostic.SA1117.severity = warning  # Parameters should be on same line or each on own line
dotnet_diagnostic.SA1122.severity = warning  # Use string.Empty for empty strings
dotnet_diagnostic.SA1127.severity = warning  # Generic type constraints should be on their own line
dotnet_diagnostic.SA1202.severity = warning  # Elements should be ordered by access
dotnet_diagnostic.SA1208.severity = warning  # System using directives should be placed before other using directives
dotnet_diagnostic.SA1400.severity = warning  # Access modifier should be declared
dotnet_diagnostic.SA1413.severity = warning  # Use trailing comma in multi-line initializers
dotnet_diagnostic.SA1512.severity = warning  # Single-line comments should not be followed by blank line
dotnet_diagnostic.SA1515.severity = warning  # Single-line comment should be preceded by blank line
dotnet_diagnostic.SA1600.severity = suggestion  # Elements should be documented (set to suggestion not warning)
dotnet_diagnostic.SA1649.severity = warning  # File name should match first type name
dotnet_diagnostic.SA1633.severity = none  # File header
dotnet_diagnostic.SA1200.severity = none  # Using directives placement (conflicts with our setting)
dotnet_diagnostic.SA1101.severity = none  # Prefix local calls with this

# SonarAnalyzer rules
dotnet_diagnostic.S125.severity = warning  # Remove commented out code
dotnet_diagnostic.S1075.severity = suggestion  # Refactor hardcoded absolute paths or URIs
dotnet_diagnostic.S1135.severity = suggestion  # Complete the task associated to this TODO comment
dotnet_diagnostic.S3903.severity = warning  # Move types into a named namespace
dotnet_diagnostic.S6966.severity = suggestion  # Await RunAsync instead

# Security Code Scan rules
dotnet_diagnostic.SCS0005.severity = suggestion  # Weak random number generator

# Compiler warnings as errors for better code quality
dotnet_diagnostic.CS8600.severity = error  # Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8601.severity = error  # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = error  # Dereference of a possibly null reference
dotnet_diagnostic.CS8603.severity = error  # Possible null reference return
dotnet_diagnostic.CS8604.severity = error  # Possible null reference argument
dotnet_diagnostic.CS8618.severity = error  # Non-nullable field must contain a non-null value when exiting constructor
dotnet_diagnostic.CS8625.severity = error  # Cannot convert null literal to non-nullable reference type
