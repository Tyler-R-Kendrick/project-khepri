<web-app>
  <display-name>Legacy Payment Monolith</display-name>
  <servlet>
    <servlet-name>PaymentServlet</servlet-name>
    <servlet-class>legacy.payments.PaymentServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>PaymentServlet</servlet-name>
    <url-pattern>/payments</url-pattern>
  </servlet-mapping>
  <env-entry>
    <env-entry-name>classloader.resource.lookup</env-entry-name>
    <env-entry-value>legacy-payment.properties</env-entry-value>
  </env-entry>
</web-app>
