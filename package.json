{
  "name": "project-khepri-agent-evals",
  "private": true,
  "type": "module",
  "scripts": {
    "eval:agents": "agentv eval run evals/github-agents/khepri-github-agents.eval.yaml --dry-run --threshold 1 --workers 1",
    "eval:agents:validate": "agentv validate evals/github-agents/khepri-github-agents.eval.yaml --max-warnings 0",
    "lint:agents": "node scripts/lint-agent-frontmatter.mjs",
    "postinstall": "node scripts/patch-squad-postinstall.mjs",
    "preeval:agents": "npm run lint:agents",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "agent-evals:dry-run": "agentevals run --dry-run",
    "squad:build": "squad build",
    "squad:check": "squad build --check",
    "squad:doctor": "squad doctor",
    "squad:status": "squad status",
    "skills:validate": "skills-ref validate .github/skills/learn && skills-ref validate .github/skills/spec-kit && skills-ref validate .github/skills/khepri-modernization-workflow && skills-ref validate .github/skills/keep-architecture-docs-current",
    "skills:validate:architecture-docs": "skills-ref validate .github/skills/keep-architecture-docs-current",
    "skills:validate:spec-kit": "skills-ref validate .github/skills/spec-kit",
    "speckit:check": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/skills/spec-kit/scripts/check-spec-kit.ps1",
    "sensei:spec-kit": "uv run --with gepa --with litellm python .agents/skills/sensei/scripts/gepa/auto_evaluator.py score --skill spec-kit --skills-dir .github/skills --tests-dir tests --json",
    "webui:build": "npm --prefix webui run build",
    "webui:dev": "npm --prefix webui run dev",
    "webui:preview": "npm --prefix webui run preview",
    "webui:typecheck": "npm --prefix webui run typecheck"
  },
  "devDependencies": {
    "@bradygaster/squad-cli": "0.9.4",
    "@bradygaster/squad-sdk": "0.9.4",
    "@github/copilot-sdk": "^0.3.0",
    "@langchain/core": "^1.1.45",
    "@microsoft/agents-hosting": "^1.5.1",
    "@nem035/agentevals": "^0.1.2",
    "@types/node": "^25.6.0",
    "agentevals": "^0.0.7",
    "agentv": "4.24.1",
    "skills-ref": "0.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=20.12"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.91.1",
    "@microsoft/agents-hosting": {
      "axios": "1.16.0"
    },
    "@microsoft/agents-activity": {
      "uuid": "11.1.1"
    },
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/exporter-prometheus": "0.218.0"
  }
}
